@{
    ViewData["Title"] = "Kết Quả MBTI";
    var personalityType = ViewBag.PersonalityType as string ?? "INTJ";
}

<div class="bg-light py-4">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-controller="CareerTest" asp-action="Index">Bài Test MBTI</a></li>
                <li class="breadcrumb-item active">Kết Quả</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container py-5">
    <div class="text-center mb-5">
        <i class="fas fa-check-circle fa-5x text-success mb-3"></i>
        <h1 class="text-success">Hoàn Thành Bài Đánh Giá!</h1>
        <p class="lead">Dưới đây là kết quả đánh giá tính cách MBTI của bạn</p>

        <div class="result-badge d-inline-block mb-4">
            <i class="fas fa-user me-2"></i> Loại tính cách: <span id="personality-type">@personalityType</span>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-md-6 mb-4">
            <div class="card h-100 career-match-card">
                <div class="card-body">
                    <h4 class="card-title text-primary">Nghề nghiệp phù hợp nhất</h4>
                    <h5 class="text-secondary" id="top-career">Kỹ sư phần mềm</h5>
                    <p class="card-text" id="top-career-desc">Phù hợp với tính cách phân tích và kỹ thuật của bạn. Bạn có khả năng giải quyết vấn đề và làm việc với hệ thống phức tạp.</p>
                    <div class="mt-3">
                        <span class="badge bg-primary">Độ phù hợp: 92%</span>
                        <span class="badge bg-success ms-2">Thu nhập cao</span>
                        <span class="badge bg-info ms-2">Cơ hội tốt</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h4 class="card-title text-primary">Mô tả tính cách</h4>
                    <h5 class="text-secondary" id="personality-title">Nhà chiến lược</h5>
                    <p class="card-text" id="personality-desc">Bạn có tư duy chiến lược, độc lập và quyết đoán. Bạn thích làm việc với ý tưởng và lập kế hoạch dài hạn. Khả năng phân tích và giải quyết vấn đề của bạn rất xuất sắc.</p>

                    <h6 class="mt-4">Ưu điểm nổi bật:</h6>
                    <ul>
                        <li>Tư duy logic và chiến lược</li>
                        <li>Độc lập và tự chủ</li>
                        <li>Khả năng phân tích sâu</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="mb-5">
        <h3 class="section-title">Các ngành nghề khác phù hợp</h3>
        <div class="row" id="other-careers">
            <div class="col-md-4 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5>Phân tích dữ liệu</h5>
                        <p class="card-text">Làm việc với dữ liệu lớn, phân tích xu hướng và đưa ra insights có giá trị.</p>
                        <div class="mt-3">
                            <span class="badge bg-primary">Phù hợp: 92%</span>
                            <span class="badge bg-secondary ms-2">Công nghệ</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5>Quản lý dự án</h5>
                        <p class="card-text">Lập kế hoạch, điều phối và quản lý các dự án từ đầu đến cuối.</p>
                        <div class="mt-3">
                            <span class="badge bg-primary">Phù hợp: 88%</span>
                            <span class="badge bg-secondary ms-2">Quản lý</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5>Thiết kế UX/UI</h5>
                        <p class="card-text">Thiết kế trải nghiệm người dùng và giao diện cho sản phẩm số.</p>
                        <div class="mt-3">
                            <span class="badge bg-primary">Phù hợp: 85%</span>
                            <span class="badge bg-secondary ms-2">Sáng tạo</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center mt-4">
        <a asp-controller="CareerTest" asp-action="Test" class="btn btn-primary">
            <i class="fas fa-redo me-2"></i>Làm lại đánh giá
        </a>
        <button class="btn btn-outline-primary ms-2">
            <i class="fas fa-download me-2"></i>Tải kết quả
        </button>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary ms-2">
            <i class="fas fa-home me-2"></i>Về trang chủ
        </a>
    </div>
</div>
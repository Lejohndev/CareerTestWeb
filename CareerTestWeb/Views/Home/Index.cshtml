@{
    ViewData["Title"] = "Home Page";
}


<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card">
                <div class="card-header py-3">
                    <h5 class="m-0 font-weight-bold"><i class="fas fa-graduation-cap me-2"></i>Đánh Giá Nghề Nghiệp Phù Hợp</h5>
                </div>
                <div class="card-body">
                    <!-- Introduction -->
                    <div id="intro-section">
                        <div class="text-center mb-4">
                            <img src="https://nscs.org/wp-content/uploads/2025/02/careertest-800.png" alt="Career evaluation" class="img-fluid mb-3" style="max-height: 150px;">
                            <h3 class="text-primary">Khám phá nghề nghiệp phù hợp với tính cách của bạn</h3>
                            <p class="lead">Bài đánh giá này sẽ giúp bạn xác định ngành nghề phù hợp dựa trên tính cách và sở thích cá nhân</p>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <div class="card h-100">
                                    <div class="card-body text-center">
                                        <i class="fas fa-clock fa-3x text-primary mb-3"></i>
                                        <h5>Thời gian ngắn</h5>
                                        <p>Chỉ mất khoảng 10-15 phút để hoàn thành</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 mb-4">
                                <div class="card h-100">
                                    <div class="card-body text-center">
                                        <i class="fas fa-chart-pie fa-3x text-primary mb-3"></i>
                                        <h5>Phân tích chi tiết</h5>
                                        <p>Nhận kết quả đánh giá chi tiết về nghề nghiệp phù hợp</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 mb-4">
                                <div class="card h-100">
                                    <div class="card-body text-center">
                                        <i class="fas fa-chart-pie fa-3x text-primary mb-3"></i>
                                        <h5>Phân tích chi tiết</h5>
                                        <p>Nhận kết quả đánh giá chi tiết về nghề nghiệp phù hợp</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="text-center mt-4">
                            <button id="start-btn" class="btn btn-primary btn-lg">Bắt đầu đánh giá <i class="fas fa-arrow-right ms-2"></i></button>
                        </div>
                    </div>

                    <!-- Questions Section -->
                    <div id="questions-section" style="display: none;">
                        <div class="step-indicator">
                            <div class="step active">1</div>
                            <div class="step">2</div>
                            <div class="step">3</div>
                            <div class="step">4</div>
                            <div class="step">5</div>
                        </div>

                        <div class="progress">
                            <div class="progress-bar" role="progressbar" style="width: 20%;" aria-valuenow="20" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>

                        <div class="question-container">
                            <h4 class="mb-4">Bạn thích làm việc trong môi trường như thế nào?</h4>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="radio" name="question1" id="q1Option1">
                                <label class="form-check-label" for="q1Option1">
                                    Môi trường có cấu trúc rõ ràng, ổn định
                                </label>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="radio" name="question1" id="q1Option2">
                                <label class="form-check-label" for="q1Option2">
                                    Môi trường năng động, sáng tạo
                                </label>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="radio" name="question1" id="q1Option3">
                                <label class="form-check-label" for="q1Option3">
                                    Môi trường giúp đỡ người khác, có ý nghĩa xã hội
                                </label>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="radio" name="question1" id="q1Option4">
                                <label class="form-check-label" for="q1Option4">
                                    Môi trường cạnh tranh, hướng đến kết quả
                                </label>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between">
                            <button id="prev-btn" class="btn btn-secondary" disabled><i class="fas fa-arrow-left me-2"></i>Quay lại</button>
                            <button id="next-btn" class="btn btn-primary">Tiếp theo <i class="fas fa-arrow-right ms-2"></i></button>
                        </div>
                    </div>

                    <!-- Results Section -->
                    <div id="results-section" style="display: none;">
                        <div class="text-center mb-5">
                            <i class="fas fa-check-circle fa-5x text-success mb-3"></i>
                            <h3 class="text-success">Hoàn thành đánh giá!</h3>
                            <p>Dưới đây là kết quả đánh giá nghề nghiệp phù hợp với bạn</p>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <div class="card result-card h-100">
                                    <div class="card-body">
                                        <h5 class="card-title text-primary">Nghề nghiệp phù hợp nhất</h5>
                                        <h6 class="text-secondary">Kỹ sư phần mềm</h6>
                                        <p class="card-text">Phù hợp với tính cách phân tích và kỹ thuật của bạn. Bạn có khả năng giải quyết vấn đề và làm việc với hệ thống phức tạp.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 mb-4">
                                <div class="card result-card h-100">
                                    <div class="card-body">
                                        <h5 class="card-title text-primary">Tính cách nổi bật</h5>
                                        <h6 class="text-secondary">INTJ - Nhà chiến lược</h6>
                                        <p class="card-text">Bạn có tư duy chiến lược, độc lập và quyết đoán. Bạn thích làm việc với ý tưởng và lập kế hoạch dài hạn.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4">
                            <h5 class="mb-3">Các ngành nghề khác phù hợp</h5>
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <div class="card">
                                        <div class="card-body">
                                            <h6>Phân tích dữ liệu</h6>
                                            <small class="text-muted">Phù hợp: 92%</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <div class="card">
                                        <div class="card-body">
                                            <h6>Quản lý dự án</h6>
                                            <small class="text-muted">Phù hợp: 88%</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <div class="card">
                                        <div class="card-body">
                                            <h6>Thiết kế UX/UI</h6>
                                            <small class="text-muted">Phù hợp: 85%</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-center mt-4">
                            <button id="restart-btn" class="btn btn-primary"><i class="fas fa-redo me-2"></i>Làm lại đánh giá</button>
                            <button class="btn btn-outline-primary ms-2"><i class="fas fa-download me-2"></i>Tải kết quả</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>